<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Oportunidades — CRM 2Tes</title>
  <link rel="stylesheet" href="/styles/sidebarstyle.css" />
  <link rel="stylesheet" href="/styles/oportunidadesstyle.css" />
</head>
<body>
  <%- include('partials/sidebar') %>
  <main>
    <section class="card-painel">
      <div class="header-section">

        <h2>Oportunidades</h2>
        <% if (message) { %>
          <div class="alert alert-error" role="alert" aria-live="assertive">
            <span class="alert-text"><%= message %></span>
            <button class="alert-close" aria-label="Fechar alerta">&times;</button>
          </div>
        <% } %>
      </div>

      <div class="toolbar">
        <button id="btnNovaOportunidade" class="add-button">+ Nova Oportunidade</button>
        <input id="searchOportunidade" class="search-input" type="search" placeholder="Pesquisar oportunidade...">
      </div>

        <div class="table-container">
          <table>
            <thead>
              <tr>
                <th>Nome</th>
                <th>Cliente</th>
                <th>Valor</th>
                <th>Etapa</th>
                <th>Ações</th>
              </tr>
            </thead>
            <tbody>
              <% if (!oportunidades || oportunidades.length === 0) { %>
                <tr><td colspan="5" class="empty-msg">Nenhuma oportunidade cadastrada.</td></tr>
              <% } else { %>
                <% oportunidades.forEach(item => { %>
                  <tr>
                    <td class="bold-text"><%= item.nome %></td>
                    <td><%= item.cliente || '-' %></td>
                    <td class="valor-text">R$ <%= item.valor.toFixed(2) %></td>
                    <td><span class="etapa-badge <%= item.etapa.toLowerCase() %>"><%= item.etapa %></span></td>
                    <td>
                      <button type="button" class="action edit" 
                        data-id="<%= item.id %>"
                        data-nome="<%= item.nome %>"
                        data-cliente_id="<%= item.cliente_id || '' %>"
                        data-valor="<%= item.valor %>"
                        data-etapa="<%= item.etapa %>"
                        data-anotacoes="<%= item.anotacoes || '' %>">Editar</button>
                      <form action="/oportunidades/<%= item.id %>/delete" method="post" style="display:inline; margin-left:8px;">
                        <button type="submit" class="delete-btn">Excluir</button>
                      </form>
                    </td>
                  </tr>
                <% }) %>
              <% } %>
            </tbody>
          </table>
      </div>

        

      <div id="modalOportunidade" class="modal hidden">
        <div class="modal-content">
          <div class="modal-header">
            <h2>Nova Oportunidade</h2>
            <span id="closeModal" class="close">&times;</span>
          </div>

            <% if (typeof fieldErrors !== 'undefined' && fieldErrors && fieldErrors._global) { %>
              <div class="error-message" role="alert" aria-live="assertive">
                <div class="error-content">
                  <span class="error-icon" aria-hidden="true">⚠️</span>
                  <div class="error-text"><strong>Erro:</strong> <span><%= fieldErrors._global %></span></div>
                  <button class="error-close" aria-label="Fechar mensagem">&times;</button>
                </div>
              </div>
            <% } %>
            
            <form id="oportunidadeForm" action="/oportunidades" method="post">
              <input type="hidden" name="id" value="" />
              <div class="field-group">
                  <label>Título da Oportunidade</label>
                  <input name="nome" type="text" placeholder="Ex: Venda de Software" value="<%= (typeof values !== 'undefined' && values && values.nome) ? values.nome : '' %>" class="<%= (typeof fieldErrors !== 'undefined' && fieldErrors && fieldErrors.nome) ? 'input-error' : '' %>" />
                  <% if (typeof fieldErrors !== 'undefined' && fieldErrors && fieldErrors.nome) { %>
                    <div class="field-error"><%= fieldErrors.nome %></div>
                  <% } %>
              </div>
              
              <div class="field-group">
                <label>Cliente Relacionado</label>
                <select name="cliente_id" class="<%= (typeof fieldErrors !== 'undefined' && fieldErrors && fieldErrors.cliente_id) ? 'input-error' : '' %>">
                  <option value="" disabled <%= !(typeof values !== 'undefined' && values && values.cliente_id) ? 'selected' : '' %>>Selecione um cliente...</option>
                  <% clientes.forEach(cliente => { %>
                    <option value="<%= cliente.id %>" <%= (typeof values !== 'undefined' && values && String(values.cliente_id) === String(cliente.id)) ? 'selected' : '' %>><%= cliente.nome %></option>
                  <% }) %>
                </select>
                <% if (typeof fieldErrors !== 'undefined' && fieldErrors && fieldErrors.cliente_id) { %>
                  <div class="field-error"><%= fieldErrors.cliente_id %></div>
                <% } %>
              </div>

              <div class="field-row-grid">
                <div class="field-group">
                  <label>Valor (R$)</label>
                  <input name="valor" type="number" step="0.01" placeholder="0,00" value="<%= (typeof values !== 'undefined' && values && values.valor) ? values.valor : '' %>" class="<%= (typeof fieldErrors !== 'undefined' && fieldErrors && fieldErrors.valor) ? 'input-error' : '' %>" />
                  <% if (typeof fieldErrors !== 'undefined' && fieldErrors && fieldErrors.valor) { %>
                    <div class="field-error"><%= fieldErrors.valor %></div>
                  <% } %>
                </div>
                <div class="field-group">
                  <label>Etapa Atual</label>
                  <select name="etapa" class="<%= (typeof fieldErrors !== 'undefined' && fieldErrors && fieldErrors.etapa) ? 'input-error' : '' %>">
                    <option value="Contato" <%= (typeof values !== 'undefined' && values && values.etapa === 'Contato') ? 'selected' : '' %>>Contato</option>
                    <option value="Proposta" <%= (typeof values !== 'undefined' && values && values.etapa === 'Proposta') ? 'selected' : '' %>>Proposta</option>
                    <option value="Negociação" <%= (typeof values !== 'undefined' && values && values.etapa === 'Negociação') ? 'selected' : '' %>>Negociação</option>
                    <option value="Fechamento" <%= (typeof values !== 'undefined' && values && values.etapa === 'Fechamento') ? 'selected' : '' %>>Fechamento</option>
                    <option value="Perdida" <%= (typeof values !== 'undefined' && values && values.etapa === 'Perdida') ? 'selected' : '' %>>Perdida</option>
                  </select>
                  <% if (typeof fieldErrors !== 'undefined' && fieldErrors && fieldErrors.etapa) { %>
                    <div class="field-error"><%= fieldErrors.etapa %></div>
                  <% } %>
                </div>
              </div>

              <div class="field-group">
                <label>Anotações</label>
                <textarea name="anotacoes" rows="3" placeholder="Observações..." class="<%= (typeof fieldErrors !== 'undefined' && fieldErrors && fieldErrors.anotacoes) ? 'input-error' : '' %>"><%= (typeof values !== 'undefined' && values && values.anotacoes) ? values.anotacoes : '' %></textarea>
                <% if (typeof fieldErrors !== 'undefined' && fieldErrors && fieldErrors.anotacoes) { %>
                  <div class="field-error"><%= fieldErrors.anotacoes %></div>
                <% } %>
              </div>

              <button type="submit" class="save-btn">Salvar Oportunidade</button>
          </form>

        </div>
      </div>

    </section>



  </main>

  <script>
    const modal = document.getElementById('modalOportunidade');
    const btnNova = document.getElementById('btnNovaOportunidade');
    const spanClose = document.getElementById('closeModal');
    const modalError = document.querySelector('.modal .error-message') || document.querySelector('.modal .field-error');

    btnNova.onclick = () => modal.classList.remove('hidden');
    spanClose.onclick = () => modal.classList.add('hidden');
    window.onclick = event => {
      if (event.target === modal) {
        modal.classList.add('hidden');
      }
    };

    // Manter modal aberta se houver erro
    if (modalError) {
      modal.classList.remove('hidden');
    }
  </script>

  <script src="/static/scripts/alerts.js" defer></script>
  <script src="/static/scripts/search.js" defer></script>
  <script src="/static/scripts/edit.js" defer></script>
  <script src="/static/scripts/confirm-delete.js" defer></script>

</body>
</html>