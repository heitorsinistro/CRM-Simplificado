<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Oportunidades — CRM 2Tes</title>
  <link rel="stylesheet" href="../public/styles/sidebarstyle.css" />
  <link rel="stylesheet" href="../public/styles/oportunidadesstyle.css" />
</head>
<body>
  <%- include('partials/sidebar') %>
  <main>
    <section class="card">
      <h2>Oportunidades</h2>
      <% if (message) { %>
        <div class="error-message"><%= message %></div>
      <% } %>

      <form class="oportunidade-form" action="/oportunidades" method="post">
        <div class="field-row">
          <label>Nome</label>
          <input name="nome" type="text" required />
        </div>
        <div class="field-row">
          <label>Cliente</label>
          <select name="cliente_id" required>
            <option value="">Selecione um cliente</option>
            <% clientes.forEach(cliente => { %>
              <option value="<%= cliente.id %>"><%= cliente.nome %></option>
            <% }) %>
          </select>
        </div>
        <div class="field-row">
          <label>Valor (R$)</label>
          <input name="valor" type="number" step="0.01" required />
        </div>
        <div class="field-row">
          <label>Etapa</label>
          <select name="etapa" required>
            <option>Contato</option>
            <option>Proposta</option>
            <option>Negociação</option>
            <option>Fechamento</option>
            <option>Perdida</option>
          </select>
        </div>
        <div class="field-row">
          <label>Anotações</label>
          <textarea name="anotacoes"></textarea>
        </div>
        <button type="submit" class="save">Salvar Oportunidade</button>
      </form>

      <table>
        <thead>
          <tr>
            <th>Nome</th>
            <th>Cliente</th>
            <th>Valor</th>
            <th>Etapa</th>
            <th>Ações</th>
          </tr>
        </thead>
        <tbody>
          <% if (!oportunidades || oportunidades.length === 0) { %>
            <tr><td colspan="5">Nenhuma oportunidade cadastrada.</td></tr>
          <% } else { %>
            <% oportunidades.forEach(item => { %>
              <tr>
                <td><%= item.nome %></td>
                <td><%= item.cliente || '-' %></td>
                <td>R$ <%= item.valor.toFixed(2) %></td>
                <td><%= item.etapa %></td>
                <td>
                  <form action="/oportunidades/<%= item.id %>/delete" method="post" style="display:inline;">
                    <button type="submit" class="delete-button">Excluir</button>
                  </form>
                </td>
              </tr>
            <% }) %>
          <% } %>
        </tbody>
      </table>
    </section>
  </main>
</body>
</html>