<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Oportunidades — CRM 2Tes</title>
  <link rel="stylesheet" href="/styles/sidebarstyle.css" />
  <link rel="stylesheet" href="/styles/oportunidadesstyle.css" />
</head>
<body>
  <%- include('partials/sidebar') %>
  <main>
    <section class="card">
      <h2>Oportunidades</h2>
      <% if (message) { %>
        <div class="error-message"><%= message %></div>
      <% } %>

      <div class="toolbar">
          <button id="btnNovaOportunidade" class="add-button">+ Nova Oportunidade</button>
          <input id="searchOportunidade" class="search-input" type="search" placeholder="Pesquisar por nome...">
      </div>

      <div id="modalOportunidade" class="modal hidden">
        <div class="modal-content">
          <span id="closeModal" class="close">&times;</span>
          <h2>Adicionar Nova Oportunidade</h2>
          <form id="oportunidadeForm" action="/oportunidades" method="post">
            <div class="field-row">
              <label>Nome</label>
              <input name="nome" type="text" required />
            </div>
            <div class="field-row">
              <label>Cliente (opcional)</label>
              <select name="cliente_id">
                <option value="">Nenhum</option>
                <% clientes.forEach(cliente => { %>
                  <option value="<%= cliente.id %>"><%= cliente.nome %></option>
                <% }) %>
              </select>
            </div>
            <div class="field-row">
              <label>Valor</label>
              <input name="valor" type="number" step="0.01" required />
            </div>
            <div class="field-row">
              <label>Etapa</label>
              <select name="etapa" required>
                <option>Lead</option>
                <option>Contato Inicial</option>
                <option>Proposta Enviada</option>
                <option>Negociação</option>
                <option>Fechado - Ganhou</option>
                <option>Fechado - Perdido</option>
              </select>
            </div>
            <button type="submit" class="save">Salvar Oportunidade</button>
          </form>
        </div>
      </div>

      <table>
        <thead>
          <tr>
            <th>Nome</th>
            <th>Cliente</th>
            <th>Valor</th>
            <th>Etapa</th>
            <th>Ações</th>
          </tr>
        </thead>
        <tbody>
          <% if (!oportunidades || oportunidades.length === 0) { %>
            <tr><td colspan="5">Nenhuma oportunidade cadastrada.</td></tr>
          <% } else { %>
            <% oportunidades.forEach(item => { %>
              <tr>
                <td><%= item.nome %></td>
                <td><%= item.cliente || '-' %></td>
                <td>R$ <%= item.valor.toFixed(2) %></td>
                <td><%= item.etapa %></td>
                <td>
                  <form action="/oportunidades/<%= item.id %>/delete" method="post" style="display:inline;">
                    <button type="submit" class="delete-button">Excluir</button>
                  </form>
                </td>
              </tr>
            <% }) %>
          <% } %>
        </tbody>
      </table>
    </section>
  </main>

  <script>
    const modal = document.getElementById('modalOportunidade');
    const btnNova = document.getElementById('btnNovaOportunidade');
    const spanClose = document.getElementById('closeModal');

    btnNova.onclick = () => modal.classList.remove('hidden');
    spanClose.onclick = () => modal.classList.add('hidden');
    window.onclick = event => {
      if (event.target === modal) {
        modal.classList.add('hidden');
      }
    };
  </script>

</body>
</html>