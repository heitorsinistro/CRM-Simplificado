<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="stylesheet" href="/styles/loginstyle.css" />
  <title>Login — CRM 2Tes</title>
</head>
<body>
  <header>
    <strong>CRM 2Tes</strong> — Sistema Simplificado
  </header>

  <div class="login-container">
    <h1>Bem-vindo de volta</h1>

    <% if (message) { %>
      <div class="error-message" role="alert" aria-live="assertive">
        <div class="error-content">
          <span class="error-icon" aria-hidden="true">⚠️</span>
          <div class="error-text"><strong>Erro:</strong> <span><%= message %></span></div>
          <button class="error-close" aria-label="Fechar mensagem">&times;</button>
        </div>
      </div>
    <% } %>
    
    <form action="/auth/login" method="POST">
      <label for="email">Email</label>
      <input type="email" id="email" name="email" placeholder="Seu email" value="<%= (typeof values !== 'undefined' && values && values.email) ? values.email : '' %>" class="<%= (typeof fieldErrors !== 'undefined' && fieldErrors && fieldErrors.email) ? 'input-error' : '' %>" aria-invalid="<%= (typeof fieldErrors !== 'undefined' && fieldErrors && fieldErrors.email) ? 'true' : 'false' %>" />
      <% if (typeof fieldErrors !== 'undefined' && fieldErrors && fieldErrors.email) { %>
        <div class="field-error"><%= fieldErrors.email %></div>
      <% } %>

      <label for="senha">Senha</label>
      <input type="password" id="senha" name="senha" placeholder="Sua senha" class="<%= (typeof fieldErrors !== 'undefined' && fieldErrors && fieldErrors.senha) ? 'input-error' : '' %>" aria-invalid="<%= (typeof fieldErrors !== 'undefined' && fieldErrors && fieldErrors.senha) ? 'true' : 'false' %>" />
      <% if (typeof fieldErrors !== 'undefined' && fieldErrors && fieldErrors.senha) { %>
        <div class="field-error"><%= fieldErrors.senha %></div>
      <% } %>

      <button type="submit">Login</button>
      
      <p class="continue">ou continue com</p>
      
      <button type="button" class="btn-google">Entrar com Google</button>
    </form>

    <div class="signup-link">
      Não tem uma conta? <a href="/registro">Registre-se aqui!</a>
    </div>
    
  </div>
  <script src="/static/scripts/alerts.js" defer></script>
</body>
</html>