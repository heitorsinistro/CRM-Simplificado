<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="stylesheet" href="/styles/loginstyle.css" />
  <title>Registro — CRM 2Tes</title>
</head>
<body>
  <header>
    <strong>CRM 2Tes</strong> — Sistema Simplificado
  </header>

  <div class="login-container">
    <h1>Crie sua conta</h1>
    <% if (message) { %>
      <div class="alert alert-error" role="alert" aria-live="assertive">
        <span class="alert-text"><%= message %></span>
        <button class="alert-close" aria-label="Fechar alerta">&times;</button>
      </div>
    <% } %>
    <form action="/auth/register" method="POST">
      <label for="nome">Nome Completo</label>
      <input type="text" name="nome" id="nome" placeholder="Seu nome completo" required />

      <label for="email">Email</label>
      <input type="email" name="email" id="email" placeholder="Seu email" required />

      <label for="senha">Senha</label>
      <input type="password" name="senha" id="senha" placeholder="Sua senha" required />

      <button type="submit">Registrar</button>

      <p class="continue">ou registre-se com</p>
      
      <button type="button" class="btn-google">Registrar com Google</button>
    </form>

    <div class="signup-link">
      Já tem uma conta? <a href="/login">Faça login aqui</a>
    </div>
  </div>
  <script src="/static/scripts/alerts.js" defer></script>
</body>
</html>