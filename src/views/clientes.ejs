<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Clientes — CRM 2Tes</title>
  <link rel="stylesheet" href="/styles/clientesstyle.css" />
  <link rel="stylesheet" href="/styles/sidebarstyle.css" />
</head>
<body>
  <%- include('partials/sidebar') %>
  <main>
    <section class="card">
      <h2>Clientes</h2>
      <% if (message) { %>
        <div class="alert alert-error" role="alert" aria-live="assertive">
          <span class="alert-text"><%= message %></span>
          <button class="alert-close" aria-label="Fechar alerta">&times;</button>
        </div>
      <% } %>

      <div class="toolbar">
          <button id="btnNovoCliente" class="add-button">+ Adicionar Cliente</button>
          <input id="searchNome" class="search-input" type="search" placeholder="Pesquisar por nome...">
      </div>

      <div id="modalCliente" class="modal hidden">
        <div class="modal-content">
          <span id="closeModal" class="close">&times;</span>
          <h2>Adicionar Novo Cliente</h2>
          <% if (modalError) { %>
            <div class="alert alert-error" role="alert" aria-live="assertive">
              <span class="alert-text"><%= modalError %></span>
              <button class="alert-close" aria-label="Fechar alerta">&times;</button>
            </div>
          <% } %>
          <form id="clienteForm" action="/clientes" method="post">
            <div class="field-row">
              <label>Nome</label>
              <input name="nome" type="text" />
            </div>
            <div class="field-row">
              <label>Empresa</label>
              <input name="empresa" type="text" />
            </div>
            <div class="field-row">
              <label>Email</label>
              <input name="email" type="email" />
            </div>
            <div class="field-row">
              <label>Telefone</label>
              <input name="telefone" type="text" />
            </div>
            <div class="field-row">
              <label>Categoria</label>
              <select name="categoria" required>
                <option value="lead">Lead</option>
                <option value="contato">Contato</option>
                <option value="qualificado">Qualificado</option>
                <option value="cliente_ativo">Cliente Ativo</option>
                <option value="cliente_inativo">Cliente Inativo</option>
                <option value="cliente_perdido">Cliente Perdido</option>
              </select>
            </div>
            <div class="field-row">
              <label>Anotações</label>
              <textarea name="anotacoes" rows="3"></textarea>
            </div>
            <button type="submit" class="save">Salvar Cliente</button>
          </form>

        </div>
      </div>

      <table>
        <thead>
          <tr>
            <th>Nome</th>
            <th>Empresa</th>
            <th>Email</th>
            <th>Telefone</th>
            <th>Ações</th>
          </tr>
        </thead>
        <tbody>
          <% if (!clientes || clientes.length === 0) { %>
            <tr><td colspan="5">Nenhum cliente cadastrado.</td></tr>
          <% } else { %>
            <% clientes.forEach(cliente => { %>
              <tr>
                <td><%= cliente.nome %></td>
                <td><%= cliente.empresa || '-' %></td>
                <td><%= cliente.email %></td>
                <td><%= cliente.telefone || '-' %></td>
                <td>
                  <form action="/clientes/<%= cliente.id %>/delete" method="post" style="display:inline;">
                    <button type="submit" class="delete-button">Excluir</button>
                  </form>
                </td>
              </tr>
            <% }) %>
          <% } %>
        </tbody>
      </table>
    </section>
  </main>

  <script>
    const btnNovoCliente = document.getElementById('btnNovoCliente');
    const modalCliente = document.getElementById('modalCliente');
    const closeModal = document.getElementById('closeModal');
    const modalError = document.querySelector('.modal .alert');

    btnNovoCliente.addEventListener('click', () => {
      modalCliente.classList.remove('hidden');
    });

    closeModal.addEventListener('click', () => {
      modalCliente.classList.add('hidden');
    });

    window.addEventListener('click', (event) => {
      if (event.target === modalCliente) {
        modalCliente.classList.add('hidden');
      }
    });

    // Manter modal aberta se houver erro
    if (modalError) {
      modalCliente.classList.remove('hidden');
    }
  </script>
  <script src="/static/scripts/alerts.js" defer></script>
</body>
</html>
