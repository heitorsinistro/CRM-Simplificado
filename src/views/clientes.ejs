<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Clientes — CRM 2Tes</title>
  <link rel="stylesheet" href="/styles/clientesstyle.css" />
  <link rel="stylesheet" href="/styles/sidebarstyle.css" />
</head>
<body>
  <%- include('partials/sidebar') %>
  <main>
    <section class="card">
      <h2>Clientes</h2>
      <% if (message) { %>
        <div class="alert alert-error" role="alert" aria-live="assertive">
          <span class="alert-text"><%= message %></span>
          <button class="alert-close" aria-label="Fechar alerta">&times;</button>
        </div>
      <% } %>

      <div class="toolbar">
          <button id="btnNovoCliente" class="add-button">+ Adicionar Cliente</button>
          <input id="searchNome" class="search-input" type="search" placeholder="Pesquisar por nome...">
      </div>

      <div id="modalCliente" class="modal hidden">
        <div class="modal-content">
          <span id="closeModal" class="close">&times;</span>
          <h2>Adicionar Novo Cliente</h2>
          <% if (typeof fieldErrors !== 'undefined' && fieldErrors && fieldErrors._global) { %>
            <div class="error-message" role="alert" aria-live="assertive">
              <div class="error-content">
                <span class="error-icon" aria-hidden="true">⚠️</span>
                <div class="error-text"><strong>Erro:</strong> <span><%= fieldErrors._global %></span></div>
                <button class="error-close" aria-label="Fechar mensagem">&times;</button>
              </div>
            </div>
          <% } %>
          <form id="clienteForm" action="/clientes" method="post">
            <div class="field-row">
              <label>Nome</label>
              <input name="nome" type="text" value="<%= (typeof values !== 'undefined' && values && values.nome) ? values.nome : '' %>" class="<%= (typeof fieldErrors !== 'undefined' && fieldErrors && fieldErrors.nome) ? 'input-error' : '' %>" />
              <% if (typeof fieldErrors !== 'undefined' && fieldErrors && fieldErrors.nome) { %>
                <div class="field-error"><%= fieldErrors.nome %></div>
              <% } %>
            </div>
            <div class="field-row">
              <label>Empresa</label>
              <input name="empresa" type="text" value="<%= (typeof values !== 'undefined' && values && values.empresa) ? values.empresa : '' %>" class="<%= (typeof fieldErrors !== 'undefined' && fieldErrors && fieldErrors.empresa) ? 'input-error' : '' %>" />
              <% if (typeof fieldErrors !== 'undefined' && fieldErrors && fieldErrors.empresa) { %>
                <div class="field-error"><%= fieldErrors.empresa %></div>
              <% } %>
            </div>
            <div class="field-row">
              <label>Email</label>
              <input name="email" type="email" value="<%= (typeof values !== 'undefined' && values && values.email) ? values.email : '' %>" class="<%= (typeof fieldErrors !== 'undefined' && fieldErrors && fieldErrors.email) ? 'input-error' : '' %>" />
              <% if (typeof fieldErrors !== 'undefined' && fieldErrors && fieldErrors.email) { %>
                <div class="field-error"><%= fieldErrors.email %></div>
              <% } %>
            </div>
            <div class="field-row">
              <label>Telefone</label>
              <input name="telefone" type="text" value="<%= (typeof values !== 'undefined' && values && values.telefone) ? values.telefone : '' %>" class="<%= (typeof fieldErrors !== 'undefined' && fieldErrors && fieldErrors.telefone) ? 'input-error' : '' %>" />
              <% if (typeof fieldErrors !== 'undefined' && fieldErrors && fieldErrors.telefone) { %>
                <div class="field-error"><%= fieldErrors.telefone %></div>
              <% } %>
            </div>
            <div class="field-row">
              <label>Categoria</label>
              <select name="categoria" required class="<%= (typeof fieldErrors !== 'undefined' && fieldErrors && fieldErrors.categoria) ? 'input-error' : '' %>">
                <option value="lead" <%= (typeof values !== 'undefined' && values && values.categoria === 'lead') ? 'selected' : '' %>>Lead</option>
                <option value="contato" <%= (typeof values !== 'undefined' && values && values.categoria === 'contato') ? 'selected' : '' %>>Contato</option>
                <option value="qualificado" <%= (typeof values !== 'undefined' && values && values.categoria === 'qualificado') ? 'selected' : '' %>>Qualificado</option>
                <option value="cliente_ativo" <%= (typeof values !== 'undefined' && values && values.categoria === 'cliente_ativo') ? 'selected' : '' %>>Cliente Ativo</option>
                <option value="cliente_inativo" <%= (typeof values !== 'undefined' && values && values.categoria === 'cliente_inativo') ? 'selected' : '' %>>Cliente Inativo</option>
                <option value="cliente_perdido" <%= (typeof values !== 'undefined' && values && values.categoria === 'cliente_perdido') ? 'selected' : '' %>>Cliente Perdido</option>
              </select>
              <% if (typeof fieldErrors !== 'undefined' && fieldErrors && fieldErrors.categoria) { %>
                <div class="field-error"><%= fieldErrors.categoria %></div>
              <% } %>
            </div>
            <div class="field-row">
              <label>Anotações</label>
              <textarea name="anotacoes" rows="3" class="<%= (typeof fieldErrors !== 'undefined' && fieldErrors && fieldErrors.anotacoes) ? 'input-error' : '' %>"><%= (typeof values !== 'undefined' && values && values.anotacoes) ? values.anotacoes : '' %></textarea>
              <% if (typeof fieldErrors !== 'undefined' && fieldErrors && fieldErrors.anotacoes) { %>
                <div class="field-error"><%= fieldErrors.anotacoes %></div>
              <% } %>
            </div>
            <button type="submit" class="save">Salvar Cliente</button>
          </form>

        </div>
      </div>

      <table>
        <thead>
          <tr>
            <th>Nome</th>
            <th>Empresa</th>
            <th>Email</th>
            <th>Telefone</th>
            <th>Ações</th>
          </tr>
        </thead>
        <tbody>
          <% if (!clientes || clientes.length === 0) { %>
            <tr><td colspan="5">Nenhum cliente cadastrado.</td></tr>
          <% } else { %>
            <% clientes.forEach(cliente => { %>
              <tr>
                <td><%= cliente.nome %></td>
                <td><%= cliente.empresa || '-' %></td>
                <td><%= cliente.email %></td>
                <td><%= cliente.telefone || '-' %></td>
                <td>
                  <button type="button" class="action edit" 
                    data-id="<%= cliente.id %>" 
                    data-nome="<%= cliente.nome %>" 
                    data-empresa="<%= cliente.empresa || '' %>" 
                    data-email="<%= cliente.email %>" 
                    data-telefone="<%= cliente.telefone || '' %>" 
                    data-categoria="<%= cliente.categoria %>" 
                    data-anotacoes="<%= cliente.anotacoes || '' %>">Editar</button>
                  <form action="/clientes/<%= cliente.id %>/delete" method="post" style="display:inline; margin-left:8px;">
                    <button type="submit" class="delete-btn">Excluir</button>
                  </form>
                </td>
              </tr>
            <% }) %>
          <% } %>
        </tbody>
      </table>
    </section>
  </main>

  <script>
    const btnNovoCliente = document.getElementById('btnNovoCliente');
    const modalCliente = document.getElementById('modalCliente');
    const closeModal = document.getElementById('closeModal');
    const modalError = document.querySelector('.modal .error-message') || document.querySelector('.modal .field-error');

    btnNovoCliente.addEventListener('click', () => {
      modalCliente.classList.remove('hidden');
    });

    closeModal.addEventListener('click', () => {
      modalCliente.classList.add('hidden');
    });

    window.addEventListener('click', (event) => {
      if (event.target === modalCliente) {
        modalCliente.classList.add('hidden');
      }
    });

    // Manter modal aberta se houver erro
    if (modalError) {
      modalCliente.classList.remove('hidden');
    }
  </script>
  <script src="/static/scripts/alerts.js" defer></script>
  <script src="/static/scripts/search.js" defer></script>
  <script src="/static/scripts/edit.js" defer></script>
</body>
</html>
